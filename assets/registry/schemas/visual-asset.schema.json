{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hs-mgt-game.invalid/schemas/visual-asset.schema.json",
  "title": "Health Policy Strategy Game visual asset entry",
  "type": "object",
  "required": ["id", "asset_type", "semantic_role", "source_path", "release_path", "creator", "creation_method", "license", "modifications", "original_hash", "release_hash", "attribution_text", "accessible_equivalent", "visible_source", "approval_status", "provenance"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "asset_type": {"const": "visual"},
    "semantic_role": {"type": "string", "minLength": 1},
    "source_path": {"type": ["string", "null"]},
    "release_path": {"type": ["string", "null"]},
    "creator": {"type": "string", "minLength": 1},
    "creation_method": {"type": "string", "minLength": 1},
    "license": {"type": "string", "minLength": 1},
    "modifications": {"type": "string", "minLength": 1},
    "original_hash": {"type": ["string", "null"]},
    "release_hash": {"type": ["string", "null"]},
    "attribution_text": {"type": "string", "minLength": 1},
    "accessible_equivalent": {"type": "string", "minLength": 1},
    "visible_source": {"type": "string", "minLength": 1},
    "approval_status": {"enum": ["approved", "pending", "rejected"]},
    "provenance": {
      "type": "object",
      "required": ["kind", "source_url", "retrieval_date", "license_reference"],
      "properties": {
        "kind": {"enum": ["repository-authored", "local-generation", "external"]},
        "source_url": {"type": ["string", "null"]},
        "retrieval_date": {"type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "license_reference": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  }
}
